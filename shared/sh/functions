#!/bin/sh

# Add a directory to PATH if not already present
addToPath() {
  if [[ "$PATH" != *"$1"* ]]; then
    export PATH=$PATH:$1
  fi
}

# Source a file only if it exists
source_if_exists() {
  if [ -f $1 ]; then
    source $1
  fi
}

# Copy stdin to clipboard (supports wl-copy and pbcopy)
copy() {
  if command -v wl-copy &> /dev/null; then
    wl-copy
  elif command -v pbcopy &> /dev/null; then
    pbcopy
  else
    echo "Error: Neither wl-copy nor pbcopy is available" >&2
    return 1
  fi
}

# List git repos in the current directory with branch, last commit, and change status
gitls() {
  local RED=$(tput setaf 1)
  local CYAN=$(tput setaf 6)
  local RESET=$(tput sgr0)

  printf "Directory|Current Branch|Last Commit Date|Uncommitted Changes?\n"
  for dir in ./*/; do
    # Skip if not a git repo
    if ! [[ -d $dir/.git ]]; then
      printf "${RED}%s is not a git repo|||${RESET}\n" "$dir"
      continue
    fi

    # Skip if no commits
    if ! git -C "$dir" rev-parse --quiet --verify HEAD >/dev/null; then
      printf "${RED}%s has no commits yet|||${RESET}\n" "$dir"
      continue
    fi

    changes_present_label=""
    current_branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD)
    # Get the date of the most recent commit
    last_commit_date=$(git -C "$dir" log -1 --format=%cd --date=short)
    number_of_files_changed=$(git -C "$dir" status --short | wc -l)

    if [[ $number_of_files_changed -gt 0 ]]; then
      changes_present_label="${CYAN}Changes${RESET}"
    fi

    printf "%s|%s|%s|%s\n" "$dir" "$current_branch" "$last_commit_date" "$changes_present_label"
  done | column -t -s'|'
}

# Run RSpec on a file with documentation format and quickfix output
function spec() {
	bundle exec rspec "$1" --format documentation --require $HOME/.local/bin/quickfix_formatter.rb --format QuickfixFormatter --out /tmp/quickfix.out
}

# Fuzzy checkout a git branch using fzf
function checkout() {
	git checkout $(git branch | fzf --reverse)
}

# Create a tmux layout with an AI assistant pane, a small shell pane, and the editor
tmux-code() {
  local current_dir="${PWD}"
  local ai_agent="${1:-copilot}"
  
  local ai_cmd
  case "$ai_agent" in
    copilot)
      ai_cmd="copilot --yolo"
      ;;
    opencode)
      ai_cmd="opencode"
      ;;
    claude)
      ai_cmd="claude"
      ;;
    *)
      echo "Unknown AI agent: $ai_agent" >&2
      echo "Usage: tl [copilot|opencode|claude]" >&2
      return 1
      ;;
  esac

  # Left pane (current): nvim
  tmux split-window -h -p 33 -c "$current_dir"
  tmux send-keys "$ai_cmd" C-m

  # Split left pane to add small bottom shell
  tmux select-pane -L
  tmux split-window -v -p 15 -c "$current_dir"

  # Focus top-left for nvim
  tmux select-pane -U
  tmux send-keys "$EDITOR ." C-m
}
