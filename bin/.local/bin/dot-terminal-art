#!/usr/bin/env bash
# Display embedded terminal art

set -euo pipefail

if [[ "${1:-}" == "--help" ]]; then
    echo "Usage: dot-terminal-art <art>"
    echo ""
    echo "Arguments:"
    echo "  ct"
    echo "  c3"
    exit 0
fi

if [[ -z "${1:-}" ]]; then
    echo "ERROR: art name is required" >&2
    echo "Usage: dot-terminal-art <ct|c3>" >&2
    exit 1
fi

ART_C3=""

ART_CT=""

case "$1" in
    c3) echo "$ART_C3" | base64 -D ;;
    ct) echo "$ART_CT" | base64 -D ;;
    *)
        echo "ERROR: unknown art '$1' (expected: ct, c3)" >&2
        exit 1
        ;;
esac
