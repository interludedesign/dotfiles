#!/usr/bin/env bash
# Create a new work skill with a standard SKILL.md front-matter

set -euo pipefail

if [[ -z "${SKILLS_DIR:-}" ]]; then
  echo "ERROR: SKILLS_DIR is not set" >&2
  exit 1
fi

if [[ "${1:-}" == "--help" || $# -lt 1 ]]; then
  echo "Usage: dot-skill-new <skill-name>"
  echo ""
  echo "Creates a new skill directory at \$SKILLS_DIR/.claude/skills/<skill-name>/"
  echo "and populates SKILL.md with standard front-matter."
  echo ""
  echo "Naming conventions:"
  echo "  create-*         Skills whose primary job is to produce output"
  echo "  guide-{project}- How to do something in a specific project"
  echo "  domain-{project} Business domain knowledge for a project"
  echo "  styleguide-{lang} Language-level code style conventions"
  echo ""
  echo "Env vars:"
  echo "  SKILLS_DIR  Path to the skills directory (required)"
  exit 0
fi

SKILL_NAME="$1"
SKILL_DIR="${SKILLS_DIR}/.claude/skills/${SKILL_NAME}"

if [[ -d "${SKILL_DIR}" ]]; then
  echo "ERROR: Skill already exists: ${SKILL_DIR}" >&2
  exit 1
fi

mkdir -p "${SKILL_DIR}"

cat > "${SKILL_DIR}/SKILL.md" <<EOF
---
name: ${SKILL_NAME}
description: TODO: describe when this skill should be used
---

# TODO: Skill Title

## When to Use

- TODO: list triggers and scenarios

## Prerequisites

1. TODO

## Workflow

1. TODO

EOF

echo "OK: Created ${SKILL_DIR}/SKILL.md"
