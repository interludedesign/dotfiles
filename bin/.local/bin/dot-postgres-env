#!/usr/bin/env bash
# Sourced by postgres utility scripts to set shared connection defaults

missing=()
[ -z "$PGHOST" ] && missing+=("PGHOST")
[ -z "$PGPORT" ] && missing+=("PGPORT")
[ -z "$PGUSER" ] && missing+=("PGUSER")
[ -z "$PGPASSWORD" ] && missing+=("PGPASSWORD")
[ -z "$PGDATABASE" ] && missing+=("PGDATABASE")

if [ ${#missing[@]} -gt 0 ]; then
    echo "Error: missing required environment variables: ${missing[*]}" >&2
    echo "" >&2
    echo "Add the following to your shell config:" >&2
    for var in "${missing[@]}"; do
        echo "export ${var}=" >&2
    done
    exit 1
fi

host="$PGHOST"
port="$PGPORT"
user="$PGUSER"
password="$PGPASSWORD"
database="$PGDATABASE"
