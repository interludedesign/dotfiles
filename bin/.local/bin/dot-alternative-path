#!/usr/bin/env bash
# alt - Find alternate files
# Usage: alt <filepath>

set -euo pipefail

file="${1:-}"

if [ -z "$file" ]; then
    echo "Usage: alt <filepath>" >&2
    exit 1
fi

# Get the directory and filename
dir=$(dirname "$file")
base=$(basename "$file")

# Try .alt.toml in project root first
project_root=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
alt_config="$project_root/.alt.toml"

if [ -f "$alt_config" ]; then
    # Parse .alt.toml for patterns
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip comments and empty lines
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ -z "$line" ]] && continue
        
        # Parse pattern="replacement" lines
        if [[ "$line" =~ ^([^=]+)=\"(.+)\"$ ]]; then
            pattern="${BASH_REMATCH[1]}"
            replacement="${BASH_REMATCH[2]}"
            
            # Try to match the file against the pattern
            # Convert shell pattern to regex
            regex_pattern="${pattern//\*/.*}"
            regex_pattern="${regex_pattern//\?/.}"
            
            if [[ "$file" =~ ^${regex_pattern}$ ]]; then
                # Extract capture groups (simplified: use ${BASH_REMATCH} from the file path)
                # For now, handle common Ruby/Rails patterns
                result="$replacement"
                
                # Replace $1, $2 etc with captured groups
                # This is a simplified version
                if [[ "$file" =~ app/(controllers|models|helpers|views|services|jobs|mailers|channels)/(.+)\.rb$ ]]; then
                    type="${BASH_REMATCH[1]}"
                    name="${BASH_REMATCH[2]}"
                    
                    # Check if this is a test file pattern
                    if [[ "$replacement" == *"test/"* ]] || [[ "$replacement" == *"spec/"* ]]; then
                        test_path="${replacement/\$1/$type}"
                        test_path="${test_path/\$2/$name}"
                        
                        if [ -f "$test_path" ]; then
                            echo "$test_path"
                            exit 0
                        fi
                    fi
                elif [[ "$file" =~ test/(.+)_test\.rb$ ]] || [[ "$file" =~ spec/(.+)_spec\.rb$ ]]; then
                    # Going from test to implementation
                    test_type="${BASH_REMATCH[1]}"
                    
                    if [[ "$replacement" == *"app/"* ]]; then
                        impl_path="${replacement/\$1/$test_type}"
                        
                        if [ -f "$impl_path" ]; then
                            echo "$impl_path"
                            exit 0
                        fi
                    fi
                fi
            fi
        fi
    done < "$alt_config"
fi

# C# patterns: find alternate by searching for file by name
# Source -> Test: src/.../Name.cs -> tests/.../NameTests.cs
if [[ "$file" =~ ^(.*)/src/(.+)/([^/]+)\.cs$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    name="${BASH_REMATCH[3]}"
    test_name="${name}Tests"
    tests_dir="${prefix}/tests"

    if [ -d "$tests_dir" ]; then
        result=$(find "$tests_dir" -name "${test_name}.cs" 2>/dev/null | head -1)
        if [ -n "$result" ]; then
            echo "$result"
            exit 0
        fi
    fi
# Test -> Source: tests/.../NameTests.cs -> src/.../Name.cs
elif [[ "$file" =~ ^(.*)/tests/(.+)/([^/]+)Tests\.cs$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    name="${BASH_REMATCH[3]}"
    src_dir="${prefix}/src"

    if [ -d "$src_dir" ]; then
        result=$(find "$src_dir" -name "${name}.cs" 2>/dev/null | head -1)
        if [ -n "$result" ]; then
            echo "$result"
            exit 0
        fi
    fi
fi

# Default Ruby/Rails patterns if no .alt.toml or no match found
# Pattern: app/<type>/<name>.rb <-> test/<type>/<name>_test.rb
if [[ "$file" =~ ^(.*/)?app/([^/]+)/(.+)\.rb$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    type="${BASH_REMATCH[2]}"
    name="${BASH_REMATCH[3]}"
    
    # Try test/models/lead_test.rb pattern
    test_file="${prefix}test/${type}/${name}_test.rb"
    if [ -f "$test_file" ]; then
        echo "$test_file"
        exit 0
    fi
    
    # Try spec/models/lead_spec.rb pattern
    spec_file="${prefix}spec/${type}/${name}_spec.rb"
    if [ -f "$spec_file" ]; then
        echo "$spec_file"
        exit 0
    fi
elif [[ "$file" =~ ^(.*/)?test/([^/]+)/(.+)_test\.rb$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    type="${BASH_REMATCH[2]}"
    name="${BASH_REMATCH[3]}"
    
    impl_file="${prefix}app/${type}/${name}.rb"
    if [ -f "$impl_file" ]; then
        echo "$impl_file"
        exit 0
    fi
elif [[ "$file" =~ ^(.*/)?spec/([^/]+)/(.+)_spec\.rb$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    type="${BASH_REMATCH[2]}"
    name="${BASH_REMATCH[3]}"
    
    impl_file="${prefix}app/${type}/${name}.rb"
    if [ -f "$impl_file" ]; then
        echo "$impl_file"
        exit 0
    fi
fi

# No match found
exit 1
